---
interface Props {
  activePath?: string;
}

const { activePath = "/" } = Astro.props;

import { navItems } from "../data/navigation";
import logoLightUrl from "../assets/icons/logo-light.svg?url";
import instagramIconUrl from "../assets/icons/instagram-alt.svg?url";
import facebookIconUrl from "../assets/icons/facebook.svg?url";
import tiktokIconUrl from "../assets/icons/tiktok.svg?url";

const isActive = (href: string) => activePath === href;
---

<header class="header">
  <a class="header__link" href="/">
    <img class="header__logo" src={logoLightUrl} alt="Logo du festival Echos Sonore" />
  </a>

  <nav class="header__desktop-nav" aria-label="Navigation principale">
    <ul class="header__desktop-list u-list-unstyled">
      {navItems.map((item) => (
        <li class="header__desktop-item">
          <a class={`header__desktop-link ${isActive(item.href) ? "header__desktop-link--active" : ""}`.trim()} href={item.href}>
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <button class="header__menu-btn menu-btn" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="mainNav">
    <span class="menu-btn__bar menu-btn__bar--top" aria-hidden="true"></span>
    <span class="menu-btn__bar menu-btn__bar--middle" aria-hidden="true"></span>
    <span class="menu-btn__bar menu-btn__bar--bottom" aria-hidden="true"></span>
  </button>

  <nav class="header__menu menu" id="mainNav" hidden>
    <ul class="menu__list u-list-unstyled">
      {navItems.map((item) => (
        <li class="menu__item">
          <a class={`menu__link ${isActive(item.href) ? "menu__link--active" : ""}`.trim()} href={item.href}>
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <ul class="menu__social-list u-list-unstyled">
      <li class="menu__social-item">
        <a class="menu__social-link" href="#" aria-label="Instagram">
          <img src={instagramIconUrl} alt="instagram-icon" class="menu__social-icon" loading="lazy" />
        </a>
      </li>
      <li class="menu__social-item">
        <a class="menu__social-link" href="#" aria-label="Facebook">
          <img src={facebookIconUrl} alt="facebook-icon" class="menu__social-icon" loading="lazy" />
        </a>
      </li>
      <li class="menu__social-item">
        <a class="menu__social-link" href="#" aria-label="TikTok">
          <img src={tiktokIconUrl} alt="tiktok-icon" class="menu__social-icon" loading="lazy" />
        </a>
      </li>
    </ul>
  </nav>
</header>
