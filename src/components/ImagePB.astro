---
const { src = "", alt = "Image", className = "", loading = "lazy", fallbackLabel = "Aucune image" } = Astro.props;
---

{src ? (
  <img src={src} alt={alt} class={className} loading={loading} />
) : (
  <div class={`grid place-items-center bg-slate-800 text-slate-200 text-xs ${className}`}>
    {fallbackLabel}
  </div>
)}
