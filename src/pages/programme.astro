---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const title = "Programme — Echos Sonores";
const description = "Programme complet d'Echos Sonores avec planning des concerts et activites.";
const currentPath = "/programme";

const dayFilters = ["TOUS", "VEN 10.28", "SAM 10.29", "DIM 10.30", "LUN 10.31"];

const programmeDays = [
  {
    date: "28 oct",
    shows: [
      "18h — Mystic Echoes (Dub)",
      "19h30 — Naya & The Vibrations (Fusion)",
      "21h — Jah Roots Collective (Roots)",
      "22h30 — BassLine Dub System (Dub)",
    ],
  },
  {
    date: "29 oct",
    shows: ["17h30 — Kora Sunlight (Fusion)", "19h — Dub Strikers (Dub)", "21h — Lion Fire Crew (Roots)"],
  },
  {
    date: "30 oct",
    shows: ["18h — Soul of Irie (Roots)", "20h — Electric Dub Tribe (Fusion)", "22h — Rasta Motion (Roots)"],
  },
  {
    date: "31 oct",
    shows: ["17h30 — Tribal Echo (Fusion)", "19h — Zion Pulse (Roots)", "21h30 — Midnight Dub Circle (Dub)"],
  },
];
---

<BaseLayout title={title} description={description}>
<Header activePath={currentPath} />
    
    <main>
      <section class="section section--wrapper programme">
        <header class="section__header programme__header">
          <h1 class="section__title programme__title">Programme</h1>
          <p class="programme__lead">
            Retrouvez la programmation complète d'Echos Sonores: quatre jours de concerts
            reggae, dub et fusion, avec des artistes confirmés et émergents.
          </p>
          <nav class="programme-filters" aria-label="Filtrer le programme par jour">
            {
              dayFilters.map((filter, index) => (
                <button class={`programme-filters__btn ${index === 0 ? "programme-filters__btn--active" : ""}`} type="button">
                  {filter}
                </button>
              ))
            }
          </nav>
        </header>
    
        <div class="programme-days">
    
          {
            programmeDays.map((day) => (
              <article class="programme-day" data-aos="fade-down">
                <h2 class="programme-day__title">{day.date}</h2>

                <ul class="programme-day__list u-list-unstyled">
                  {day.shows.map((show) => <li class="programme-day__item">{show}</li>)}
                </ul>
              </article>
            ))
          }
        </div>
    
        <div class="programme__cta" data-aos="fade-down">
          <a class="btn btn--light programme__btn" href="/assets/doc/programme-echos-sonore.pdf" target="_blank"
            rel="noopener noreferrer">
            Télécharger programme PDF
          </a>
        </div>
      </section>
    </main>

    <Footer />

</BaseLayout>
