---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import SceneListItem from "../../components/SceneListItem.astro";
import { photos } from "../../data/photos.ts";
import { fetchScenes, fileUrl } from "../../lib/collections";

const title = "Scenes - Echos Sonores";
const description = "Vue d'ensemble des scenes du festival Echos Sonores et des univers proposes.";
const currentPath = "/scenes";
const scenes = await fetchScenes();
const sceneFallbacks = [photos.scene1.src, photos.scene2.src, photos.scene3.src];
---

<BaseLayout title={title} description={description} includeLightbox={false}>
  <Header activePath={currentPath} />

  <main>
    <section class="section section--wrapper scenes" data-aos="fade-up" data-aos-duration="900">
      <header class="section__header scenes__header" data-aos="fade-up" data-aos-duration="900" data-aos-delay="80">
        <h1 class="section__title scenes__title">Les Scenes du Echos Sonores</h1>
      </header>

      {
        scenes.length === 0 ? (
          <p>Aucune scene disponible.</p>
        ) : (
          <ul class="scenes-list u-list-unstyled">
            {scenes.map((scene: any, index: number) => (
              <SceneListItem
                scene={scene}
                imageUrl={fileUrl(scene, "photos", "1200x800") || sceneFallbacks[index % sceneFallbacks.length]}
                aosDelay={index * 110}
              />
            ))}
          </ul>
        )
      }
    </section>
  </main>

  <Footer />
</BaseLayout>
