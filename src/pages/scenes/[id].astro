---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { concertLabel, fileUrl } from "../../lib/collections";
import { getArtistsBySceneId, getScene } from "../../../backend/backend.mjs";

const id = Astro.params.id ?? "";
const scene = await getScene(id);
if (!scene) {
	return Astro.redirect("/404");
}

const artists = await getArtistsBySceneId(id);
const sceneImage = fileUrl(scene, "photos", "1400x900");
const sceneName = scene.nom_scene ?? "Scene";
const sceneDescription = scene.description ?? "Description indisponible.";

const lineupArtists = artists.map((artist: any) => ({
  id: artist.id,
  name: artist.nom_artiste ?? "Artiste",
  date: concertLabel(artist.date_representation).split(" - ")[0],
}));
---

<BaseLayout title={`${sceneName} - Echos Sonores`} description="Detail scene">
	<Header activePath="/scenes" />
	<main class="scene-page-wrap">
		<section class="section section--wrapper scene-page">
			<button class="scene-page__back-btn" type="button" onclick="window.history.back()">
				<span aria-hidden="true">←</span>
				<span class="u-sr-only">Retour aux scenes</span>
			</button>

			<header class="scene-page__header">
				<h1 class="scene-page__title">{sceneName}</h1>
			</header>

			{sceneImage ? (
				<img class="scene-page__img" src={sceneImage} alt={`Photo de ${sceneName}`} loading="lazy" />
			) : (
				<div class="scene-page__img">Aucune image disponible</div>
			)}

			<div class="scene-page__panels">
				<p class="scene-page__text">{sceneDescription}</p>

				<h2 class="scene-page__subtitle">Artistes programmés :</h2>
				<section class="scene-page__lineup">
					<ul class="scene-artists u-list-unstyled">
						{lineupArtists.length === 0 ? (
							<li class="scene-artists__item">Aucun artiste programme.</li>
						) : (
							lineupArtists.map((artistes) => (
								<li class="scene-artists__item">
									<a class="scene-page__artist-link" href={`/artistes/${artistes.id}`}>
										{artistes.name} - {artistes.date}
									</a>
								</li>
							))
						)}
					</ul>
				</section>
			</div>

			<div class="scene-page__actions">
				<a class="btn scene-page__cta" href="/artistes">
					Voir tous les Artistes
				</a>
			</div>
		</section>
	</main>
	<Footer />
</BaseLayout>
