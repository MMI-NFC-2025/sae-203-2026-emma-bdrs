---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { photos } from "../data/photos.ts";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const title = "Festival — Echos Sonores";
const description = "Decouvrez le festival Echos Sonores : concept, valeurs et experience proposee.";
const currentPath = "/festival";

const festivalParagraphs = [
  "Echos Sonore est un nouveau festival de musiques actuelles dédié à la culture reggae. L’édition inaugurale se déroulera du 28 au 31 octobre 2026, à Audincourt, sur un site en plein air pouvant accueillir jusqu’à 3 000 personnes par jour.",
  "Conçu comme un rendez-vous automnal pendant les vacances universitaires, le festival propose une ambiance immersive inspirée d’Halloween, mêlant lumières, décors et scénographie nocturne.",
  "Le festival veut offrir une expérience conviviale, à taille humaine, où se rencontrent artistes, public, innovation locale et engagement citoyen.",
];

const teamMembers = [
  { src: photos.staff1, alt: "Membre de l'équipe Echos Sonores 1" },
  { src: photos.staff2, alt: "Membre de l'équipe Echos Sonores 2" },
  { src: photos.staff3, alt: "Membre de l'équipe Echos Sonores 3" },
  { src: photos.staff4, alt: "Membre de l'équipe Echos Sonores 4" },
];
---

<BaseLayout title={title} description={description}>
<Header activePath={currentPath} />
    
    <main>
      <section class="festival-hero">
        <Image class="festival-hero__img" src={photos.festival}
          alt="Feu d'artifice au-dessus d'une scène de concert" loading="lazy" />
      </section>
    
      <section class="section section--wrapper festival" data-aos="fade-up">
        <header class="section__header festival__header">
          <h1 class="section__title festival__title">
            Le FESTIVAL ECHOS SONORES
          </h1>
        </header>
    
        <div class="festival__content" data-aos="fade-up">
          {festivalParagraphs.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </section>
    
        <section class="section section--wrapper festival-team">
          <header class="section__header">
            <h2 class="section__title">
              Notre équipe
            </h2>
          </header>
        
          <div class="carousel team-carousel" aria-label="Carrousel de l'équipe du festival">
            <div class="carousel__track-wrapper">
              <div class="carousel__viewport">
                <ul class="carousel__track u-list-unstyled">
                  {
                    teamMembers.map((member) => (
                      <li class="carousel__slide team-carousel__slide">
                        <Image class="team-carousel__photo" src={member.src} alt={member.alt} loading="lazy" />
                      </li>
                    ))
                  }
                </ul>
              </div>
            </div>

            <div class="carousel__buttons-wrapper">
              <button class="carousel__button carousel__button--prev" type="button" aria-label="Membre précédent">
                ‹
              </button>
              <button class="carousel__button carousel__button--next" type="button" aria-label="Membre suivant">
                ›
              </button>
            </div>
          </div>
        </section>

    </main>
    
    <Footer />






</BaseLayout>
