---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { photos } from "../data/photos.ts";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const title = "Accueil - Echos Sonores";
const description = "Site officiel d'Echos Sonores : accueil, programme, artistes et infos pratiques du festival.";
const currentPath = "/";

const keyInfos = [
  { icon: "🕓", label: "Ouverture des portes", value: "16h00" },
  { icon: "🎵", label: "Concerts", value: "jusqu'à 0h30" },
  { icon: "📍", label: "Lieu", value: "Site en plein air – Audincourt (25)" },
  { icon: "👥", label: "Capacité", value: "jusqu'à 3 000 personnes / jour" },
];

const navCards = [
  {
    modifier: "festival",
    icon: "🎪",
    title: "Le Festival",
    text: "Un événement à taille humaine ancré dans l'écologie, la convivialité et la créativité.",
    href: "/festival",
  },
  {
    modifier: "programme",
    icon: "🎶",
    title: "Programme",
    text: "Découvrez les artistes programmés chaque jour : roots, dub, reggae fusion, world music.",
    href: "/programme",
  },
  {
    modifier: "artistes",
    icon: "🌟",
    title: "Artistes",
    text: "Accédez à la liste complète des artistes invités et émergents.",
    href: "/artistes",
  },
  {
    modifier: "infos",
    icon: "📌",
    title: "Infos pratiques",
    text: "Transports, hébergements, tarifs et accessibilité pour préparer votre venue.",
    href: "/infos",
  },
];

const values = [
  { title: "Écologique", text: "festival responsable" },
  { title: "Convivial & inclusif", text: "une grande famille" },
  { title: "Créatif & surprenant", text: "programmation audacieuse" },
];

const partners = [
  { src: photos.partenaire1, alt: "Partenaire 1" },
  { src: photos.partenaire2, alt: "Partenaire 2" },
  { src: photos.partenaire3, alt: "Partenaire 3" },
  { src: photos.partenaire4, alt: "Partenaire 4" },
];
---

<BaseLayout title={title} description={description}>
  <Header activePath={currentPath} />

  <main>
    <section class="hero">
      <div class="hero__content">
        <p class="hero__festival-name">Echos Sonore –</p>

        <h1 class="hero__title">
          Festival reggae &amp; musiques actuelles
        </h1>

        <p class="hero__meta">
          <span class="hero__dates">28 &rarr; 31 octobre 2026</span>
          <span class="hero__place">Audincourt (25)</span>
        </p>

        <a class="btn hero__cta" href="/404.html" aria-label="Accéder à la billetterie (fictive)">
          Accéder à la billetterie
        </a>
      </div>
    </section>

    <section class="section section--wrapper section--highlight">
      <header class="section__header">
        <h2 class="section__title u-sr-only">
          Informations principales du festival
        </h2>
      </header>

      <article class="info-card">
        <h3 class="info-card__title">
          28 au 31 octobre 2026
        </h3>
        <ul class="info-card__list u-list-unstyled">
          {
            keyInfos.map((item) => (
              <li class="info-card__item">
                <span class="info-card__icon" aria-hidden="true">{item.icon}</span>
                <span>
                  <strong>{item.label} :</strong>
                  {` ${item.value}`}
                </span>
              </li>
            ))
          }
        </ul>
      </article>
    </section>

    <section class="section section--wrapper section--nav-cards">
      <header class="section__header">
        <h2 class="section__title u-sr-only">
          Explorer le festival
        </h2>
      </header>

      <ul class="u-list-unstyled nav-cards">
        {
          navCards.map((card) => (
            <li class={`nav-card nav-card--${card.modifier}`} data-aos="fade-down">
              <div class="nav-card__content">
                <p class="nav-card__icon" aria-hidden="true">{card.icon}</p>
                <h3 class="nav-card__title">{card.title}</h3>
                <p class="nav-card__text">{card.text}</p>
              </div>
              <a class="nav-card__btn btn btn--ghost" href={card.href}>
                Découvrir
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="section section--wrapper section--values">
      <header class="section__header">
        <h2 class="section__title">Nos valeurs</h2>
      </header>

      <ul class="values u-list-unstyled">
        {
          values.map((item) => (
            <li class="values__item">
              <p>
                <strong>{item.title}</strong> – “{item.text}”
              </p>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="section section--wrapper section--partners">
      <header class="section__header">
        <h2 class="section__title">Nos Partenaires</h2>
      </header>

      <div class="partners">
        {
          partners.map((partner) => (
            <div class="partners__item" data-aos="zoom-in-down">
              <Image src={partner.src} alt={partner.alt} class="partners__logo" />
            </div>
          ))
        }
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
